# ─────────────────────────────────────────────────────────────────────────────
# Franklink — environment template. Copy to .env and fill in your own values.
#   cp .env.example .env
# .env is gitignored — never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-mini
AZURE_OPENAI_REASONING_DEPLOYMENT_NAME=gpt-4o-mini

# Supabase — main database (users, conversations, opportunities)
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_KEY=                       # anon key
SUPABASE_SERVICE_KEY=               # service-role key (server-side only)
POSTGRES_CONNECTION_STRING=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres

# Supabase — resources database (books, videos, courses)
RESOURCES_SUPABASE_URL=https://<project>.supabase.co
RESOURCES_SUPABASE_KEY=
RESOURCES_SUPABASE_SERVICE_KEY=

# Redis (background jobs, caching, idempotency). Local dev: redis://localhost:6379/0
REDIS_URL=redis://default:<password>@<host>:<port>
REDIS_MAX_CONNECTIONS=50
REDIS_IDEMPOTENCY_TTL=86400         # 24h
REDIS_CACHE_TTL=300                 # 5m
REDIS_RATE_LIMIT_WINDOW=60

# FastAPI
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development
DEBUG=True

# Webhooks & rate limiting
WEBHOOK_SECRET=
WEBHOOK_ENDPOINT=/webhook/photon
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Sentry (optional)
SENTRY_DSN=

# Zep knowledge-graph memory — https://app.getzep.com/
ZEP_API_KEY=
ZEP_BASE_URL=https://api.getzep.com
ZEP_ENABLED=true

# Composio — read-only Gmail + Google Calendar context
COMPOSIO_API_KEY=
COMPOSIO_BASE_URL=
COMPOSIO_ENTITY_PREFIX=franklink
COMPOSIO_GMAIL_PROVIDER=gmail
COMPOSIO_AUTH_CONFIG_ID=
COMPOSIO_GMAIL_TOOLKIT_VERSION=
LOGIN_PAGE_URL=https://<your-domain>/login

# Google OAuth + Places — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://<your-domain>/oauth/google/callback
GOOGLE_PROJECT_ID=
GOOGLE_PLACES_API_KEY=

# Legal pages
PRIVACY_POLICY_URL=
TERMS_OF_SERVICE_URL=
DATA_DELETION_URL=

# Stripe — use a TEST key (sk_test_...) for development
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:8000/payment/success
STRIPE_CANCEL_URL=http://localhost:8000/payment/cancel

# Photon — iMessage gateway (https://photon.im/)
PHOTON_SERVER_URL=https://<your-instance>.photon.codes
PHOTON_DEFAULT_NUMBER=+1XXXXXXXXXX
PHOTON_ENABLE_LISTENER=true
PHOTON_API_KEY=

# Kafka / AWS MSK. Local Docker overrides these (see docker-compose.yml).
KAFKA_BOOTSTRAP_SERVERS=<broker>:9098
KAFKA_SECURITY_PROTOCOL=SASL_SSL    # local: PLAINTEXT
KAFKA_SASL_MECHANISM=AWS_MSK_IAM    # local: (empty)
KAFKA_USERNAME=
KAFKA_PASSWORD=
KAFKA_IAM_REGION=us-east-2

# Kafka topology (defaults live in app/config.py — override only if needed)
KAFKA_CLIENT_ID=franklink
KAFKA_GROUP_ID=frank-worker
KAFKA_TOPIC_INBOUND=photon.inbound.v1
KAFKA_TOPIC_RETRY_30S=photon.inbound.retry.30s
KAFKA_TOPIC_RETRY_2M=photon.inbound.retry.2m
KAFKA_TOPIC_RETRY_10M=photon.inbound.retry.10m
KAFKA_TOPIC_DLQ=photon.inbound.dlq.v1
KAFKA_MAX_ATTEMPTS=6
KAFKA_CONSUMER_MAX_INFLIGHT=20
KAFKA_CONSUMER_MAX_BATCH=50
KAFKA_CONSUMER_POLL_MS=1000
KAFKA_CONSUMER_AUTO_OFFSET_RESET=latest
KAFKA_KEYED_CONCURRENCY_ENABLED=true
KAFKA_KEY_LOCK_IDLE_TTL_SECONDS=600
KAFKA_KEY_LOCKS_MAX_PER_PARTITION=2000
KAFKA_MAX_COMMIT_GAP_PER_PARTITION=500
KAFKA_COMMIT_GAP_RESUME_WATERMARK=200
KAFKA_PRODUCER_IDEMPOTENCE=true
PHOTON_KAFKA_IDEMPOTENCY_TTL=86400

# Local single-process mode (bypass Kafka):
#   PHOTON_INGEST_MODE=listener
#   PHOTON_CONSUMER_MODE=off
COALESCE_ENABLED=true
